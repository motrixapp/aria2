{
  "name": "protect-release-tags",
  "target": "tag",
  "enforcement": "active",
  "bypass_actors": [
    { "actor_type": "OrganizationAdmin", "actor_id": 1, "bypass_mode": "always" }
  ],
  "conditions": {
    "ref_name": {
      "include": ["refs/tags/v*-motrix.*", "refs/tags/release-*"],
      "exclude": []
    }
  },
  "rules": [
    { "type": "deletion" },
    { "type": "update", "parameters": { "update_allows_fetch_and_merge": false } }
  ]
}
