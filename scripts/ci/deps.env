# scripts/ci/deps.env — single source of truth for vendored dep versions.
# Consumed by makerelease-osx.mk (Make `include`), build-linux-deps.sh (shell
# `.`-source), Dockerfile.mingw and Dockerfile.android (COPY + `. /deps.env`).
#
# CONSTRAINT: values are LITERALS only — no $(...) / $VAR references — so GNU
# Make's recursive-assignment and POSIX shell's literal semantics agree.
# Names are UPPERCASE with no spaces around '=' (required for shell sourcing;
# also valid Make). Per-target URLs, SHA256 hashes, and configure flags stay
# local to each build file — only versions are centralized here.

ZLIB_VERSION=1.3.2
EXPAT_VERSION=2.7.5
CARES_VERSION=1.34.6
# full autoconf tag; used as sqlite-$SQLITE_VERSION
SQLITE_VERSION=autoconf-3510300
# sqlite download URL path segment (couples to version)
SQLITE_YEAR=2026
LIBSSH2_VERSION=1.11.1
GMP_VERSION=6.3.0
# Linux + Android (OpenSSL 3.5 LTS)
OPENSSL_VERSION=3.5.7

# macOS-only source-pinned deps (mingw uses Debian apt for these — unchanged):
LIBGCRYPT_VERSION=1.11.3
LIBGPGERROR_VERSION=1.59
CPPUNIT_VERSION=1.15.1
